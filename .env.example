# --- COMMUNICATIONS (Twilio & Resend) ---
TWILIO_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PH_NUM=+18551234567
RESEND_API=re_your_resend_api_key

# --- PRIMARY DATABASES (SQL & NoSQL) ---
# PostgreSQL (Master Data)
SQL_DATABASE_URL="postgresql://user:password@localhost:5432/mavhousing?schema=public"

# MongoDB (Real-time Analytics & Chat)
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net/mavhousing"

# Redis (Background Jobs & BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AI & COMPUTER VISION ---
GEMINI_API_KEY=your_google_gemini_api_key

# --- CLOUDFLARE R2 (S3-Compatible Storage) ---
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=mavhousing-media
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- APPLICATION CONFIG ---
JWT_SECRET=your_super_secret_jwt_key
PORT=3009

WEBHOOK_PROXY_URL=smee.io url